[Unit]
Description=Quiet web server (home)
After=network.target

[Service]
Type=simple
WorkingDirectory=@@REPO_DIR@@
Environment=PYTHONUNBUFFERED=1
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=CLAUDE_CONFIG_DIR=%h/.config/Claude
Environment=DISABLE_UPDATES=1
ExecStart=/usr/bin/python3 @@REPO_DIR@@/web.py
Restart=always
RestartSec=10

# Logging — uses journal by default; override locally if you want file logs
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
