# Python
__pycache__/
*.pyc
.env
venv/
.venv/

# Runtime data — per-machine, not shared

archives/
archive/
ledger/
logs/
inbox/
transcripts/

# Sessions director - .gitkeep only
sessions/*
!sessions/.gitkeep

# Data directory — .gitkeep only
data/*
!data/.gitkeep

# Contexts — gitignore everything except shared/tracked files
# Each machine has its own environment, visitor contexts, and notes-to-self.
# Shared architecture docs are tracked; everything else is local.
contexts/*
!contexts/quiet_architecture.md
!contexts/my_environment_template.md

# Identity — gitignore everything except the Quiet system prompt.
# Each Claude's identity.md is a symlink to ~/self/identity.md (local).
# Visitor identity files are per-machine.
identity/*
!identity/quiet-system-prompt.md

# Config — templates tracked, live config local
config/quiet_config.txt
config/discord_config.json

# Services — templates tracked, generated units local
services/*.service
services/*.timer
!services/*.template

# Other per-machine files
discord_config.json
unread_channels.json
static/custom.css
rag.db
data/rag.db
memory.db
